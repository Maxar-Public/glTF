{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "MAXAR_mesh_variants node extension",
    "type": "object",
    "allOf": [
        {
            "$ref": "glTFProperty.schema.json"
        }
    ],
    "properties": {
        "mappings": {
            "type": "array",
            "description": "Array of mesh to variant mappings. Each mapping defines which mesh should be used for specific variants.",
            "items": {
                "type": "object",
                "allOf": [
                    {
                        "$ref": "glTFProperty.schema.json"
                    }
                ],
                "properties": {
                    "variants": {
                        "uniqueItems": true,
                        "type": "array",
                        "description": "Array of variant index values that this mesh mapping applies to. Each index must reference a valid variant in the root extension.",
                        "items": {
                            "allOf": [
                                {
                                    "$ref": "glTFid.schema.json"
                                }
                            ],
                            "minimum": 0
                        },
                        "minItems": 1,
                        "maxItems": 256
                    },
                    "mesh": {
                        "allOf": [
                            {
                                "$ref": "glTFid.schema.json"
                            }
                        ],
                        "minimum": 0,
                        "description": "The index of the mesh in the glTF meshes array that should be used for the specified variants."
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 256,
                        "description": "Optional user-defined name for this variant mesh mapping. Should be descriptive of the mapping purpose."
                    }
                },
                "required": [
                    "variants",
                    "mesh"
                ]
            },
            "minItems": 1,
            "maxItems": 256
        }
    },
    "required": [
        "mappings"
    ]
}